<Window x:Class="GakunguWater.Views.Dialogs.ExpenseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Expense" Width="380" SizeToContent="Height" MaxHeight="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TxtTitle" Grid.Row="0" Text="Add Expense" Style="{StaticResource PageTitle}" FontSize="16"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Category" Style="{StaticResource LabelText}"/>
            <ComboBox x:Name="CboCategory" Margin="0,0,0,12">
                <ComboBoxItem Content="Electricity" IsSelected="True"/>
                <ComboBoxItem Content="Diesel"/>
                <ComboBoxItem Content="Salary"/>
                <ComboBoxItem Content="Repairs"/>
                <ComboBoxItem Content="Other"/>
            </ComboBox>

            <TextBlock Text="Description *" Style="{StaticResource LabelText}"/>
            <TextBox x:Name="TxtDescription" Style="{StaticResource TextInput}" Margin="0,0,0,12"/>

            <TextBlock Text="Amount (KES) *" Style="{StaticResource LabelText}"/>
            <TextBox x:Name="TxtAmount" Style="{StaticResource TextInput}" Margin="0,0,0,12"/>

            <TextBlock Text="Date" Style="{StaticResource LabelText}"/>
            <DatePicker x:Name="DpDate" Height="36" Margin="0,0,0,12"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource OutlineButton}" Width="80" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button x:Name="BtnSave" Content="💾 Save" Style="{StaticResource PrimaryButton}" Width="90" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
