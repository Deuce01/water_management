<Window x:Class="GakunguWater.Views.Dialogs.MeterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meter" Width="380" SizeToContent="Height" MaxHeight="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtTitle" Grid.Row="0" Text="Meter Details" Style="{StaticResource PageTitle}" FontSize="16"/>
        <TextBlock x:Name="TxtCustomerName" Grid.Row="0" Margin="0,28,0,0"
                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock Text="Meter Number *" Style="{StaticResource LabelText}"/>
            <TextBox x:Name="TxtMeterNumber" Style="{StaticResource TextInput}" Margin="0,0,0,12"/>

            <TextBlock Text="Install Date" Style="{StaticResource LabelText}"/>
            <DatePicker x:Name="DpInstall" Margin="0,0,0,12" Height="36"/>

            <CheckBox x:Name="ChkActive" Content="Meter Active" IsChecked="True" Margin="0,0,0,12"/>

            <TextBlock Text="Notes" Style="{StaticResource LabelText}"/>
            <TextBox x:Name="TxtNotes" Height="50" TextWrapping="Wrap" AcceptsReturn="True"
                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8,4" FontSize="13"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource OutlineButton}" Width="80" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button x:Name="BtnSave" Content="💾 Save" Style="{StaticResource PrimaryButton}" Width="90" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
