<Window x:Class="GakunguWater.Views.Dialogs.MpesaImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="M-Pesa Import — Review &amp; Confirm" Width="760" MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBgBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📂 M-Pesa Import — Review Matches" Style="{StaticResource PageTitle}" FontSize="16"/>

        <Border Grid.Row="1" Background="#FFF8E1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
            <TextBlock Text="⚠️ Review the matches below before posting. Unmatched rows will be skipped. Untick any rows you do NOT want to post."
                       TextWrapping="Wrap" FontSize="12" Foreground="#92400E"/>
        </Border>

        <DataGrid Grid.Row="2" x:Name="GridRows" AutoGenerateColumns="False" IsReadOnly="False"
                  CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Post?" Binding="{Binding IsMatchedEditable, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                <DataGridTextColumn Header="Receipt No"   Binding="{Binding ReceiptNo}"             Width="110" IsReadOnly="True"/>
                <DataGridTextColumn Header="Amount"       Binding="{Binding PaidIn, StringFormat='KES N2'}" Width="90" IsReadOnly="True"/>
                <DataGridTextColumn Header="Phone"        Binding="{Binding PhoneNumber}"            Width="110" IsReadOnly="True"/>
                <DataGridTextColumn Header="Name (CSV)"   Binding="{Binding FirstName}"              Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="Matched Customer" Binding="{Binding MatchedCustomerName}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="Invoice ID"   Binding="{Binding MatchedInvoiceId}"       Width="80" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock x:Name="TxtSummary" VerticalAlignment="Center" Margin="0,0,16,0"
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
            <Button Content="Cancel" Style="{StaticResource OutlineButton}" Width="80" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button Content="✅ Post Selected" Style="{StaticResource SuccessButton}" Width="130" Click="BtnPost_Click"/>
        </StackPanel>
    </Grid>
</Window>
