<Window x:Class="GakunguWater.Views.Dialogs.CustomerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer" Width="420" SizeToContent="Height" MaxHeight="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBgBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TxtTitle" Grid.Row="0" Text="Add Customer" Style="{StaticResource PageTitle}" FontSize="16"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Full Name *" Style="{StaticResource LabelText}"/>
            <TextBox x:Name="TxtName" Style="{StaticResource TextInput}" Margin="0,0,0,12"/>

            <TextBlock Text="Phone Number" Style="{StaticResource LabelText}"/>
            <TextBox x:Name="TxtPhone" Style="{StaticResource TextInput}" Margin="0,0,0,12"/>

            <TextBlock Text="Location / Village" Style="{StaticResource LabelText}"/>
            <TextBox x:Name="TxtLocation" Style="{StaticResource TextInput}" Margin="0,0,0,12"/>

            <TextBlock Text="Connection Status" Style="{StaticResource LabelText}"/>
            <ComboBox x:Name="CboStatus" Margin="0,0,0,12">
                <ComboBoxItem Content="Active"       Tag="Active" IsSelected="True"/>
                <ComboBoxItem Content="Suspended"    Tag="Suspended"/>
                <ComboBoxItem Content="Disconnected" Tag="Disconnected"/>
            </ComboBox>

            <TextBlock Text="Notes" Style="{StaticResource LabelText}"/>
            <TextBox x:Name="TxtNotes" Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10,6"
                     FontSize="13" Margin="0,0,0,12"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource OutlineButton}" Width="90" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button x:Name="BtnSave" Content="💾 Save" Style="{StaticResource PrimaryButton}" Width="100" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
