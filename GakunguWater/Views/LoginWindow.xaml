<Window x:Class="GakunguWater.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gakungu Water — Login" Height="520" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowState="Maximized" Background="#0D2137" WindowStyle="None" AllowsTransparency="True"
        Icon="pack://application:,,,/Assets/logo.png">

    <Border CornerRadius="14" ClipToBounds="True" Background="#F0F4F8" 
            HorizontalAlignment="Center" VerticalAlignment="Center" Width="420">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header / Logo -->
            <Border Grid.Row="0" Background="#1A3A5C" Padding="32,28,32,24">
                <StackPanel>
                    <Image Source="/Assets/logo.png" Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Gakungu Water Project" FontSize="20" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Management System" FontSize="13" Foreground="#8FB3D1"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Login Form -->
            <Border Grid.Row="1" Background="#F0F4F8" Padding="36,32">
            <StackPanel>
                <TextBlock Text="Sign In to Your Account" FontSize="16" FontWeight="SemiBold"
                           Foreground="#1A3A5C" Margin="0,0,0,24"/>

                <TextBlock Text="Username" Style="{StaticResource LabelText}"/>
                <TextBox x:Name="TxtUsername" Style="{StaticResource TextInput}" Margin="0,0,0,16"
                         KeyDown="TxtUsername_KeyDown"/>

                <TextBlock Text="Password" Style="{StaticResource LabelText}"/>
                <PasswordBox x:Name="PwdPassword" Style="{StaticResource PasswordInput}" Margin="0,0,0,8"
                             KeyDown="PwdPassword_KeyDown"/>

                <TextBlock x:Name="TxtError" Text="" Foreground="#E74C3C" FontSize="12"
                           Visibility="Collapsed" Margin="0,0,0,12"/>

                <Button x:Name="BtnLogin" Content="Sign In" Style="{StaticResource PrimaryButton}"
                        Height="42" Margin="0,8,0,0" Click="BtnLogin_Click"
                        FontSize="14"/>

                <TextBlock Text="Default: admin / Admin@123" Foreground="#6B7280"
                           FontSize="10" HorizontalAlignment="Center" Margin="0,16,0,0"/>
            </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
