<Page x:Class="GakunguWater.Views.Pages.TariffsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Tariffs" Background="{StaticResource PageBgBrush}">
    <Grid Margin="28,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="⚙️ Tariff Management" Style="{StaticResource PageTitle}"/>
            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                <DataGrid x:Name="GridTariffs" IsReadOnly="True" SelectionChanged="Grid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name"       Binding="{Binding Name}"                    Width="*"/>
                        <DataGridTextColumn Header="Type"       Binding="{Binding Type}"                    Width="90"/>
                        <DataGridTextColumn Header="Flat (KES)" Binding="{Binding FlatAmount, StringFormat=N2}" Width="90"/>
                        <DataGridTextColumn Header="Per m³"     Binding="{Binding PricePerCubicMeter, StringFormat=N2}" Width="80"/>
                        <DataGridTextColumn Header="Min Charge" Binding="{Binding MinCharge, StringFormat=N2}" Width="90"/>
                        <DataGridTextColumn Header="Active?"    Binding="{Binding IsActive}"                Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Edit Form -->
        <Border Grid.Column="1" Style="{StaticResource Card}" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock x:Name="TxtFormTitle" Text="New Tariff" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Name" Style="{StaticResource LabelText}"/>
                <TextBox x:Name="TxtName" Style="{StaticResource TextInput}" Margin="0,0,0,10"/>
                <TextBlock Text="Type" Style="{StaticResource LabelText}"/>
                <ComboBox x:Name="CboType" Margin="0,0,0,10" SelectionChanged="CboType_Changed">
                    <ComboBoxItem Content="Volumetric" IsSelected="True" Tag="Volumetric"/>
                    <ComboBoxItem Content="Flat Rate"  Tag="FlatRate"/>
                </ComboBox>
                <StackPanel x:Name="PanelVolume">
                    <TextBlock Text="Price per m³ (KES)" Style="{StaticResource LabelText}"/>
                    <TextBox x:Name="TxtPricePerM3" Style="{StaticResource TextInput}" Margin="0,0,0,10"/>
                    <TextBlock Text="Min Units (m³)" Style="{StaticResource LabelText}"/>
                    <TextBox x:Name="TxtMinUnits" Style="{StaticResource TextInput}" Margin="0,0,0,10" Text="0"/>
                    <TextBlock Text="Min Charge (KES)" Style="{StaticResource LabelText}"/>
                    <TextBox x:Name="TxtMinCharge" Style="{StaticResource TextInput}" Margin="0,0,0,10" Text="0"/>
                </StackPanel>
                <StackPanel x:Name="PanelFlat" Visibility="Collapsed">
                    <TextBlock Text="Flat Amount (KES)" Style="{StaticResource LabelText}"/>
                    <TextBox x:Name="TxtFlatAmount" Style="{StaticResource TextInput}" Margin="0,0,0,10"/>
                </StackPanel>
                <CheckBox x:Name="ChkActive" Content="Active (applies to new invoices)" IsChecked="True" Margin="0,0,0,12"/>
                <Button x:Name="BtnSave" Content="💾 Save Tariff" Style="{StaticResource PrimaryButton}" Click="BtnSave_Click"/>
                <Button Content="➕ New" Style="{StaticResource OutlineButton}" Margin="0,8,0,0" Click="BtnNew_Click"/>
            </StackPanel>
        </Border>
        <!-- Busy indicator -->
        <TextBlock x:Name="BusyIndicator" Text="⏳ Working…" FontSize="16" Panel.ZIndex="10"
                   Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{StaticResource PrimaryBrush}" Visibility="Collapsed"/>
    </Grid>
</Page>

