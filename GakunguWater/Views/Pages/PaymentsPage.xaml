<Page x:Class="GakunguWater.Views.Pages.PaymentsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Payments" Background="{StaticResource PageBgBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,16">
            <TextBlock Text="💵 Payments" Style="{StaticResource PageTitle}" DockPanel.Dock="Left" Margin="0"/>
            <Button x:Name="BtnMpesa" Content="📂 Import M-Pesa CSV" Style="{StaticResource OutlineButton}"
                    DockPanel.Dock="Right" Click="BtnMpesa_Click"/>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12">
            <WrapPanel>
                <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <DatePicker x:Name="DpFrom" Width="130" Margin="0,0,12,0"/>
                <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <DatePicker x:Name="DpTo" Width="130" Margin="0,0,12,0"/>
                <Button Content="🔄 Refresh" Style="{StaticResource OutlineButton}" Click="BtnRefresh_Click"/>
                <TextBlock x:Name="TxtTotals" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource SuccessBrush}" Margin="16,0,0,0"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="GridPayments" IsReadOnly="True" SelectionChanged="Grid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#"         Binding="{Binding Id}"               Width="60"/>
                    <DataGridTextColumn Header="Customer"  Binding="{Binding CustomerName}"      Width="*"/>
                    <DataGridTextColumn Header="Amount"    Binding="{Binding Amount, StringFormat='KES {0:N2}'}" Width="90"/>
                    <DataGridTextColumn Header="Method"    Binding="{Binding PaymentMethod}"     Width="80"/>
                    <DataGridTextColumn Header="M-Pesa Ref" Binding="{Binding MPesaRef}"         Width="110"/>
                    <DataGridTextColumn Header="Month"     Binding="{Binding BillingMonth}"       Width="60"/>
                    <DataGridTextColumn Header="Year"      Binding="{Binding BillingYear}"        Width="55"/>
                    <DataGridTextColumn Header="Date"      Binding="{Binding PaidAt, StringFormat='dd/MM/yyyy HH:mm'}" Width="130"/>
                    <DataGridTextColumn Header="Received By" Binding="{Binding ReceivedByUsername}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <WrapPanel Grid.Row="3" Margin="0,8,0,0">
            <Button x:Name="BtnPrintReceipt" Content="🖨️ Print Receipt" Style="{StaticResource PrimaryButton}"
                    IsEnabled="False" Click="BtnPrintReceipt_Click"/>
        </WrapPanel>
        <!-- Busy indicator -->
        <TextBlock x:Name="BusyIndicator" Text="⏳ Loading…" FontSize="16" Panel.ZIndex="10"
                   Grid.RowSpan="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{StaticResource PrimaryBrush}" Visibility="Collapsed"/>
    </Grid>
</Page>


