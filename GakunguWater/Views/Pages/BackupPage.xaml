<Page x:Class="GakunguWater.Views.Pages.BackupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Backup" Background="{StaticResource PageBgBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="💾 Database Backup" Style="{StaticResource PageTitle}"/>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Backup Settings" Style="{StaticResource SectionTitle}"/>
                <DockPanel Margin="0,0,0,12">
                    <TextBlock Text="Backup Target Path:" VerticalAlignment="Center" Width="160"/>
                    <Button Content="📁 Browse" Style="{StaticResource OutlineButton}" DockPanel.Dock="Right"
                            Margin="8,0,0,0" Click="BtnBrowse_Click" Width="80"/>
                    <TextBox x:Name="TxtPath" Style="{StaticResource TextInput}"/>
                </DockPanel>
                <WrapPanel>
                    <Button x:Name="BtnBackup" Content="💾 Run Backup Now" Style="{StaticResource PrimaryButton}"
                            Margin="0,0,10,0" Click="BtnBackup_Click"/>
                    <Button Content="💾 Save Path" Style="{StaticResource OutlineButton}" Click="BtnSavePath_Click"/>
                </WrapPanel>

                <Border Background="#F0FFF4" CornerRadius="6" Padding="12" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock x:Name="TxtLastBackup" Text="Last Backup: —" FontWeight="SemiBold"
                                   Foreground="#2ECC71"/>
                        <TextBlock Text="💡 Auto-backup runs 30 seconds after startup and every 24 hours."
                                   FontSize="11" Foreground="#4A5568" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <StackPanel>
                <TextBlock Text="Backup History" Style="{StaticResource SectionTitle}" Margin="12,12,0,8"/>
                <DataGrid x:Name="GridHistory" IsReadOnly="True" MaxHeight="350">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Backed Up At" Binding="{Binding BackupAt, StringFormat=dd/MM/yyyy HH:mm:ss}" Width="160"/>
                        <DataGridTextColumn Header="Path"         Binding="{Binding BackupPath}" Width="*"/>
                        <DataGridTextColumn Header="Success"      Binding="{Binding Success}"    Width="70"/>
                        <DataGridTextColumn Header="Size"         Binding="{Binding FileSizeBytes}"  Width="80"/>
                        <DataGridTextColumn Header="Error"        Binding="{Binding ErrorMessage}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
        <!-- Busy indicator -->
        <TextBlock x:Name="BusyIndicator" Text="⏳ Working…" FontSize="14" Panel.ZIndex="10"
                   Grid.RowSpan="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{StaticResource PrimaryBrush}" Visibility="Collapsed"/>
    </Grid>
</Page>

