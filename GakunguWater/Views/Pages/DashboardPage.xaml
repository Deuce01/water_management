<Page x:Class="GakunguWater.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard" Background="{StaticResource PageBgBrush}">
    <Grid>
        <!-- Loading overlay -->
        <TextBlock x:Name="BusyIndicator" Text="⏳ Loading…" FontSize="18" HorizontalAlignment="Center"
                   VerticalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"
                   Visibility="Collapsed" Panel.ZIndex="10"/>
        <!-- Error banner -->
        <TextBlock x:Name="TxtError" Text="" Foreground="{StaticResource DangerBrush}"
                   Margin="0,0,0,8" TextWrapping="Wrap" Visibility="Collapsed"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">
            <TextBlock Text="📊 Dashboard" Style="{StaticResource PageTitle}"/>

            <!-- KPI Cards -->
            <UniformGrid Columns="4" Margin="0,0,0,20">
                <Border Style="{StaticResource KpiCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="👥 Total Customers" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock x:Name="TxtTotalCustomers" Text="—" FontSize="32" FontWeight="Bold" Foreground="{StaticResource PrimaryLightBrush}" Margin="0,4,0,0"/>
                        <TextBlock x:Name="TxtActiveCustomers" Text="— active" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="💵 Revenue This Month" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock x:Name="TxtRevenue" Text="KES —" FontSize="26" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Margin="0,4,0,0"/>
                        <TextBlock Text="Payments received" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="⚠️ Defaulters" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock x:Name="TxtDefaulters" Text="—" FontSize="32" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" Margin="0,4,0,0"/>
                        <TextBlock Text="Overdue invoices" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource KpiCard}">
                    <StackPanel>
                        <TextBlock Text="🧾 Unpaid Invoices" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBlock x:Name="TxtUnpaidInvoices" Text="—" FontSize="32" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" Margin="0,4,0,0"/>
                        <TextBlock x:Name="TxtUnpaidTotal" Text="KES —" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Recent Activity -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Payments -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Recent Payments" Style="{StaticResource SectionTitle}"/>
                        <DataGrid x:Name="GridRecentPayments" MaxHeight="220" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Customer"     Binding="{Binding CustomerName}" Width="*"/>
                                <DataGridTextColumn Header="Amount (KES)" Binding="{Binding Amount, StringFormat=N2}" Width="100"/>
                                <DataGridTextColumn Header="Date"         Binding="{Binding PaidAt, StringFormat=dd/MM/yy}" Width="80"/>
                                <DataGridTextColumn Header="Method"       Binding="{Binding PaymentMethod}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- Top Defaulters -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Top Defaulters" Style="{StaticResource SectionTitle}"/>
                        <DataGrid x:Name="GridDefaulters" MaxHeight="220" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Customer"   Binding="{Binding CustomerName}" Width="*"/>
                                <DataGridTextColumn Header="Balance"    Binding="{Binding Balance, StringFormat=N2}" Width="90"/>
                                <DataGridTextColumn Header="Month"      Binding="{Binding BillingMonth}" Width="50"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
