<Page x:Class="GakunguWater.Views.Pages.MeterReadingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Meter Readings" Background="{StaticResource PageBgBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,16">
            <TextBlock Text="📋 Meter Readings" Style="{StaticResource PageTitle}" DockPanel.Dock="Left" Margin="0"/>
        </DockPanel>

        <!-- Month/Year Selector + Actions -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12">
            <WrapPanel>
                <TextBlock Text="Month:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="CboMonth" Width="120" SelectionChanged="Period_Changed" Margin="0,0,12,0"/>
                <TextBlock Text="Year:" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                <ComboBox x:Name="CboYear" Width="90" SelectionChanged="Period_Changed" Margin="0,0,16,0"/>
                <Button Content="📥 Load Readings" Style="{StaticResource OutlineButton}" Margin="0,0,8,0" Click="BtnLoad_Click"/>
                <Button Content="💾 Save All Readings" x:Name="BtnSave" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="BtnSave_Click"/>
                <Button Content="🧾 Generate Invoices" x:Name="BtnGenerate" Style="{StaticResource SuccessButton}" Click="BtnGenerate_Click"/>
            </WrapPanel>
        </Border>

        <!-- Reading Grid -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="GridReadings" IsReadOnly="False" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Customer"       Binding="{Binding CustomerName}" Width="*"    IsReadOnly="True"/>
                    <DataGridTextColumn Header="Meter No"       Binding="{Binding MeterNumber}"  Width="100"  IsReadOnly="True"/>
                    <DataGridTextColumn Header="Prev Reading (m³)" Binding="{Binding PreviousReading, StringFormat=F2}" Width="130" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Current Reading (m³)"  Binding="{Binding CurrentReading,  StringFormat=F2}" Width="140"/>
                    <DataGridTextColumn Header="Consumption (m³)" Binding="{Binding Consumption,    StringFormat=F2}" Width="130" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="3" x:Name="TxtStatus" Margin="0,8,0,0"
                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
        <!-- Busy indicator -->
        <TextBlock x:Name="BusyIndicator" Text="⏳ Loading…" FontSize="16" Panel.ZIndex="10"
                   Grid.RowSpan="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{StaticResource PrimaryBrush}" Visibility="Collapsed"/>
    </Grid>
</Page>

