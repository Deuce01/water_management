<Page x:Class="GakunguWater.Views.Pages.FinanceReportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Finance Report" Background="{StaticResource PageBgBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📈 Finance Report" Style="{StaticResource PageTitle}"/>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12">
            <WrapPanel>
                <ComboBox x:Name="CboMonth" Width="130" Margin="0,0,8,0"/>
                <ComboBox x:Name="CboYear" Width="90" Margin="0,0,8,0"/>
                <Button x:Name="BtnCalc" Content="📊 Calculate" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Click="BtnCalc_Click"/>
                <Button Content="🖨️ Export PDF" Style="{StaticResource OutlineButton}" Click="BtnExport_Click" x:Name="BtnExport" IsEnabled="False"/>
            </WrapPanel>
        </Border>

        <!-- Summary Tiles -->
        <UniformGrid Grid.Row="2" Columns="3" Margin="0,8,0,0">
            <Border Style="{StaticResource KpiCard}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="💵 Revenue" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBlock x:Name="TxtRevenue" Text="KES —" FontSize="28" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="📉 Expenses" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBlock x:Name="TxtExpenses" Text="KES —" FontSize="28" FontWeight="Bold" Foreground="{StaticResource DangerBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource KpiCard}">
                <StackPanel>
                    <TextBlock Text="📊 Net" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBlock x:Name="TxtNet" Text="KES —" FontSize="28" FontWeight="Bold" Margin="0,6,0,0"/>
                    <TextBlock x:Name="TxtNetLabel" Text="" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </UniformGrid>
        <!-- Busy indicator -->
        <TextBlock x:Name="BusyIndicator" Text="⏳ Loading…" FontSize="16" Panel.ZIndex="10"
                   Grid.RowSpan="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{StaticResource PrimaryBrush}" Visibility="Collapsed"/>
    </Grid>
</Page>

