<Page x:Class="GakunguWater.Views.Pages.DefaultersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Defaulters" Background="{StaticResource PageBgBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="⚠️ Defaulters" Style="{StaticResource PageTitle}"/>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12">
            <WrapPanel>
                <TextBlock Text="Overdue by (days):" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="CboDays" Width="100" Margin="0,0,12,0" SelectionChanged="CboDays_Changed">
                    <ComboBoxItem Content="0 days"  Tag="0"/>
                    <ComboBoxItem Content="15 days" Tag="15"/>
                    <ComboBoxItem Content="30 days" Tag="30" IsSelected="True"/>
                    <ComboBoxItem Content="60 days" Tag="60"/>
                    <ComboBoxItem Content="90 days" Tag="90"/>
                </ComboBox>
                <TextBlock x:Name="TxtSummary" VerticalAlignment="Center" FontWeight="SemiBold"
                           Foreground="{StaticResource DangerBrush}"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="GridDefaulters" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Customer"    Binding="{Binding CustomerName}"              Width="*"/>
                    <DataGridTextColumn Header="Phone"       Binding="{Binding PhoneNumber}"               Width="120"/>
                    <DataGridTextColumn Header="Location"    Binding="{Binding Location}"                  Width="130"/>
                    <DataGridTextColumn Header="Meter"       Binding="{Binding MeterNumber}"               Width="90"/>
                    <DataGridTextColumn Header="Month"       Binding="{Binding BillingMonth}"              Width="60"/>
                    <DataGridTextColumn Header="Due (KES)"   Binding="{Binding AmountDue, StringFormat=N2}" Width="90"/>
                    <DataGridTextColumn Header="Paid (KES)"  Binding="{Binding AmountPaid, StringFormat=N2}" Width="90"/>
                    <DataGridTextColumn Header="Balance (KES)" Binding="{Binding Balance, StringFormat=N2}" Width="100"/>
                    <DataGridTextColumn Header="Due Date"    Binding="{Binding DueDate, StringFormat=dd/MM/yyyy}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <!-- Busy indicator -->
        <TextBlock x:Name="BusyIndicator" Text="⏳ Loading…" FontSize="16" Panel.ZIndex="10"
                   Grid.RowSpan="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{StaticResource PrimaryBrush}" Visibility="Collapsed"/>
    </Grid>
</Page>

