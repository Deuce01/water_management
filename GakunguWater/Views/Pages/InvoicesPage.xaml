<Page x:Class="GakunguWater.Views.Pages.InvoicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Invoices" Background="{StaticResource PageBgBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🧾 Invoices" Style="{StaticResource PageTitle}"/>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12">
            <WrapPanel>
                <ComboBox x:Name="CboMonth" Width="120" Margin="0,0,8,0" SelectionChanged="Filter_Changed"/>
                <ComboBox x:Name="CboYear" Width="90" Margin="0,0,8,0" SelectionChanged="Filter_Changed"/>
                <ComboBox x:Name="CboStatus" Width="140" Margin="0,0,8,0" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="All Statuses" IsSelected="True" Tag=""/>
                    <ComboBoxItem Content="Unpaid"        Tag="Unpaid"/>
                    <ComboBoxItem Content="PartiallyPaid" Tag="PartiallyPaid"/>
                    <ComboBoxItem Content="Paid"          Tag="Paid"/>
                </ComboBox>
                <Button Content="🔄 Refresh" Style="{StaticResource OutlineButton}" Click="BtnRefresh_Click"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="GridInvoices" IsReadOnly="True" SelectionChanged="Grid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Invoice #"    Binding="{Binding Id}"                        Width="80"/>
                    <DataGridTextColumn Header="Customer"     Binding="{Binding CustomerName}"               Width="*"/>
                    <DataGridTextColumn Header="Meter"        Binding="{Binding MeterNumber}"                Width="90"/>
                    <DataGridTextColumn Header="Period"       Binding="{Binding BillingMonth}"               Width="60"/>
                    <DataGridTextColumn Header="Year"         Binding="{Binding BillingYear}"                Width="55"/>
                    <DataGridTextColumn Header="m³"           Binding="{Binding Consumption, StringFormat=F2}" Width="70"/>
                    <DataGridTextColumn Header="Due (KES)"    Binding="{Binding AmountDue, StringFormat=N2}" Width="90"/>
                    <DataGridTextColumn Header="Paid (KES)"   Binding="{Binding AmountPaid, StringFormat=N2}" Width="90"/>
                    <DataGridTemplateColumn Header="Status"   Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource StatusBadge}"
                                        Background="{Binding Status, Converter={StaticResource InvoiceStatusToBrush}}">
                                    <TextBlock Text="{Binding Status}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <WrapPanel Grid.Row="3" Margin="0,8,0,0">
            <Button x:Name="BtnPrint" Content="🖨️ Print Invoice" Style="{StaticResource PrimaryButton}"
                    Margin="0,0,8,0" Click="BtnPrint_Click" IsEnabled="False"/>
            <Button x:Name="BtnPay" Content="💵 Log Payment" Style="{StaticResource SuccessButton}"
                    Margin="0,0,8,0" Click="BtnPay_Click" IsEnabled="False"/>
            <TextBlock x:Name="TxtCount" VerticalAlignment="Center" FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0"/>
        </WrapPanel>
        <!-- Busy indicator -->
        <TextBlock x:Name="BusyIndicator" Text="⏳ Loading…" FontSize="16" Panel.ZIndex="10"
                   Grid.RowSpan="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{StaticResource PrimaryBrush}" Visibility="Collapsed"/>
    </Grid>
</Page>

