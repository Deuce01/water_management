<Page x:Class="GakunguWater.Views.Pages.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Users" Background="{StaticResource PageBgBrush}">
    <Grid Margin="28,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="🔑 User Management" Style="{StaticResource PageTitle}"/>
            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                <DataGrid x:Name="GridUsers" IsReadOnly="True" SelectionChanged="Grid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Username"   Binding="{Binding Username}"   Width="130"/>
                        <DataGridTextColumn Header="Full Name"  Binding="{Binding FullName}"   Width="*"/>
                        <DataGridTextColumn Header="Role"       Binding="{Binding Role}"       Width="90"/>
                        <DataGridTextColumn Header="Active"     Binding="{Binding IsActive}"   Width="70"/>
                        <DataGridTextColumn Header="Last Login" Binding="{Binding LastLogin, StringFormat=dd/MM/yyyy}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
            <WrapPanel Grid.Row="2" Margin="0,8,0,0">
                <Button x:Name="BtnDisable" Content="🚫 Disable User" Style="{StaticResource DangerButton}" IsEnabled="False" Click="BtnDisable_Click" Margin="0,0,8,0"/>
                <Button x:Name="BtnEnable" Content="✅ Enable User" Style="{StaticResource SuccessButton}" IsEnabled="False" Click="BtnEnable_Click" Margin="0,0,8,0"/>
                <Button x:Name="BtnResetPwd" Content="🔒 Reset Password" Style="{StaticResource OutlineButton}" IsEnabled="False" Click="BtnReset_Click"/>
            </WrapPanel>
            <!-- Inline password reset panel -->
            <Border x:Name="PanelResetPwd" Grid.Row="2" Visibility="Collapsed"
                    Background="#FFF8E1" CornerRadius="6" Padding="12" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock x:Name="TxtResetLabel" Text="New password:" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PwdReset" Style="{StaticResource PasswordInput}" Margin="0,0,0,8"/>
                    <WrapPanel>
                        <Button Content="✅ Confirm" Style="{StaticResource SuccessButton}" Click="BtnConfirmReset_Click" Margin="0,0,8,0"/>
                        <Button Content="✖ Cancel"  Style="{StaticResource OutlineButton}"  Click="BtnCancelReset_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Create User Form -->
        <Border Grid.Column="1" Style="{StaticResource Card}" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Create New User" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="Username" Style="{StaticResource LabelText}"/>
                <TextBox x:Name="TxtUsername" Style="{StaticResource TextInput}" Margin="0,0,0,10"/>
                <TextBlock Text="Full Name" Style="{StaticResource LabelText}"/>
                <TextBox x:Name="TxtFullName" Style="{StaticResource TextInput}" Margin="0,0,0,10"/>
                <TextBlock Text="Role" Style="{StaticResource LabelText}"/>
                <ComboBox x:Name="CboRole" Margin="0,0,0,10">
                    <ComboBoxItem Content="Cashier" IsSelected="True"/>
                    <ComboBoxItem Content="Admin"/>
                </ComboBox>
                <TextBlock Text="Password" Style="{StaticResource LabelText}"/>
                <PasswordBox x:Name="PwdNew" Style="{StaticResource PasswordInput}" Margin="0,0,0,10"/>
                <Button x:Name="BtnCreate" Content="✅ Create User" Style="{StaticResource PrimaryButton}" Click="BtnCreate_Click"/>
            </StackPanel>
        </Border>
        <!-- Busy indicator -->
        <TextBlock x:Name="BusyIndicator" Text="⏳ Working…" FontSize="16" Panel.ZIndex="10"
                   Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{StaticResource PrimaryBrush}" Visibility="Collapsed"/>
    </Grid>
</Page>

