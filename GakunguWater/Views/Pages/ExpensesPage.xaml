<Page x:Class="GakunguWater.Views.Pages.ExpensesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Expenses" Background="{StaticResource PageBgBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,16">
            <TextBlock Text="📉 Expenses" Style="{StaticResource PageTitle}" DockPanel.Dock="Left" Margin="0"/>
            <Button x:Name="BtnAdd" Content="+ Add Expense" Style="{StaticResource PrimaryButton}" DockPanel.Dock="Right" Click="BtnAdd_Click"/>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12">
            <WrapPanel>
                <ComboBox x:Name="CboMonth" Width="120" Margin="0,0,8,0" SelectionChanged="Filter_Changed"/>
                <ComboBox x:Name="CboYear" Width="90" Margin="0,0,8,0" SelectionChanged="Filter_Changed"/>
                <ComboBox x:Name="CboCategory" Width="140" Margin="0,0,8,0" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="All Categories" IsSelected="True" Tag=""/>
                    <ComboBoxItem Content="Electricity" Tag="Electricity"/>
                    <ComboBoxItem Content="Diesel" Tag="Diesel"/>
                    <ComboBoxItem Content="Salary" Tag="Salary"/>
                    <ComboBoxItem Content="Repairs" Tag="Repairs"/>
                    <ComboBoxItem Content="Other" Tag="Other"/>
                </ComboBox>
                <TextBlock x:Name="TxtTotal" VerticalAlignment="Center" FontWeight="SemiBold"
                           Foreground="{StaticResource DangerBrush}" Margin="12,0,0,0"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid x:Name="GridExpenses" IsReadOnly="True" SelectionChanged="Grid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Category"    Binding="{Binding Category}"                   Width="110"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}"                Width="*"/>
                    <DataGridTextColumn Header="Amount (KES)" Binding="{Binding Amount, StringFormat=N2}"   Width="110"/>
                    <DataGridTextColumn Header="Date"        Binding="{Binding ExpenseDate, StringFormat=dd/MM/yyyy}" Width="90"/>
                    <DataGridTextColumn Header="Entered By"  Binding="{Binding EnteredByUsername}"          Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <WrapPanel Grid.Row="3" Margin="0,8,0,0">
            <Button x:Name="BtnEdit" Content="✏️ Edit" Style="{StaticResource OutlineButton}" IsEnabled="False" Margin="0,0,8,0" Click="BtnEdit_Click"/>
            <Button x:Name="BtnDelete" Content="🗑️ Delete" Style="{StaticResource DangerButton}" IsEnabled="False" Click="BtnDelete_Click"/>
        </WrapPanel>
        <!-- Busy indicator -->
        <TextBlock x:Name="BusyIndicator" Text="⏳ Loading…" FontSize="16" Panel.ZIndex="10"
                   Grid.RowSpan="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="{StaticResource PrimaryBrush}" Visibility="Collapsed"/>
    </Grid>
</Page>

